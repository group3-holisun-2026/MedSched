### Register a user to attach the doctor profile to
POST http://localhost:8080/api/auth/register
Content-Type: application/json

{
  "username": "dr.popescu",
  "email": "popescu@example.com",
  "passwordHash": "placeholder",
  "role": "DOCTOR"
}

> {%
    client.global.set("doctorUserId", response.body.id);
%}

###

### Get all doctors
GET http://localhost:8080/api/doctors

###

### Create doctor
POST http://localhost:8080/api/doctors
Content-Type: application/json

{
  "userId": "{{doctorUserId}}",
  "speciality": "Cardiology",
  "standardConsultationDurationMinutes": 30,
  "schedule": [
    {
      "dayOfWeek": 1,
      "startTime": "08:00",
      "endTime": "14:00"
    },
    {
      "dayOfWeek": 2,
      "startTime": "14:00",
      "endTime": "20:00"
    }
  ]
}

> {%
    client.global.set("doctorId", response.body.id);
%}

###

### Get doctor by ID
GET http://localhost:8080/api/doctors/{{doctorId}}

###

### Update doctor
PUT http://localhost:8080/api/doctors/{{doctorId}}
Content-Type: application/json

{
  "speciality": "Dermatology",
  "standardConsultationDurationMinutes": 20,
  "schedule": [
    {
      "dayOfWeek": 3,
      "startTime": "09:00",
      "endTime": "17:00"
    }
  ]
}

###

### Delete doctor
DELETE http://localhost:8080/api/doctors/{{doctorId}}
