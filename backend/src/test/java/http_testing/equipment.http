### Create a room to attach equipment to
POST http://localhost:8080/api/rooms
Content-Type: application/json

{
  "name": "Cabinet Ecografie",
  "description": "Etajul 1"
}

> {%
    client.global.set("roomId", response.body.id);
%}

###

### Create equipment type for the fixed equipment
POST http://localhost:8080/api/equipment-types
Content-Type: application/json

{
  "name": "Ecograf Doppler 4D",
  "description": "Ecograf de diagnostic"
}

> {%
    client.global.set("equipmentTypeId", response.body.id);
%}

###

### Create equipment type for the mobile equipment
POST http://localhost:8080/api/equipment-types
Content-Type: application/json

{
  "name": "Aparat ECG",
  "description": "Electrocardiograf portabil"
}

> {%
    client.global.set("mobileEquipmentTypeId", response.body.id);
%}

###

### Get all equipment
GET http://localhost:8080/api/equipment

###

### Create equipment
POST http://localhost:8080/api/equipment
Content-Type: application/json

{
  "name": "Ecograf Doppler 4D",
  "equipmentTypeId": "{{equipmentTypeId}}",
  "roomId": "{{roomId}}"
}

> {%
    client.global.set("equipmentId", response.body.id);
%}

###

### Create mobile equipment
POST http://localhost:8080/api/equipment
Content-Type: application/json

{
  "name": "Aparat ECG Portabil",
  "equipmentTypeId": "{{mobileEquipmentTypeId}}",
  "roomId": null
}

###

### Get equipment by ID
GET http://localhost:8080/api/equipment/{{equipmentId}}

###

### Update equipment
PUT http://localhost:8080/api/equipment/{{equipmentId}}
Content-Type: application/json

{
  "name": "Aparat ECG Profesional",
  "equipmentTypeId": "{{mobileEquipmentTypeId}}",
  "roomId": "{{roomId}}"
}

###

### Delete equipment
DELETE http://localhost:8080/api/equipment/{{equipmentId}}